{
  "name": "receipt-freee",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "check": "npm run check:ts && npm run check:rust",
    "check:ts": "tsc --noEmit",
    "check:rust": "cd src-tauri && cargo check",
    "lint": "cd src-tauri && cargo clippy",
    "test": "cd src-tauri && cargo test",
    "clean": "rm -rf dist && rm -rf src-tauri/target",
    "reset": "rm -f ~/Library/Application\\ Support/com.receipt-freee.app/config.json && echo 'Config reset'"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.4.2",
    "@tauri-apps/plugin-fs": "^2.4.4",
    "@tauri-apps/plugin-opener": "^2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
